# ─── App ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/xnode

# ─── Better Auth ──────────────────────────────────────
BETTER_AUTH_SECRET=your_better_auth_secret_here

# ─── OAuth (optional) ─────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Backblaze B2 ─────────────────────────────────────
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_ID=
B2_BUCKET_NAME=

# ─── Admin Panel ──────────────────────────────────────
# Super admin credentials (seeded automatically on first run)
ADMIN_USERNAME=superadmin
ADMIN_PASSWORD=change_me_super_secure_password

# Secret used to sign admin JWT sessions (must be at least 32 chars)
ADMIN_JWT_SECRET=change_me_at_least_32_chars_long_secret
